# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ITSM
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/ITSM

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# External Integrations
COLLECT_API_TOKEN=your-collect-token-here

# AI Assistant (OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server
DEBUG=True
PORT=8000
HOST=0.0.0.0

# --- Cloud & SaaS Configuration ---
# Note: AWS, Azure, and Google credentials are OPTIONAL if the application 
# is running in an environment with an attached identity (e.g. IAM Role, Managed Identity).

# Cloud: AWS 
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Cloud: Azure / M365
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# SaaS: Google Workspace
GOOGLE_APPLICATION_CREDENTIALS=  # Path to service_account.json
GOOGLE_CUSTOMER_ID=

# Enabled Providers (comma-separated: aws,azure,gcp,google_workspace)
ENABLED_PROVIDERS=aws
